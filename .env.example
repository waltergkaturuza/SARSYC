# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sarsyc_db

# Next.js Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Aliases for SMTP_PASS (same value): SMTP_PASSWORD, EMAIL_PASSWORD, MAIL_PASSWORD
SMTP_FROM=noreply@sarsyc.org

# ---------------------------------------------------------------------------
# Stanbic / N-Genius payments (Hosted Payment Page — redirect model)
# Portal (login only): https://portal.sandbox.stanbicbank.co.zw — do NOT use as STANBIC_* gateway.
# API base: https://api-gateway.sandbox.stanbicbank.co.zw (sandbox) or live api-gateway from Stanbic.
# After changing env on Vercel: redeploy so serverless picks up new values.
#
# Recommended sandbox set (aliases are equivalent to the longer names):
# STANBIC_GATEWAY_URL=https://api-gateway.sandbox.stanbicbank.co.zw
# STANBIC_REALM=StanbicBankZimbabweSandbox
# STANBIC_API_KEY=YOUR_SANDBOX_SERVICE_ACCOUNT_KEY
# STANBIC_OUTLET_REF=YOUR_SANDBOX_OUTLET_REFERENCE_UUID
# STANBIC_API_KEY_AUTHORIZATION_RAW=true   # portal “API key” = single Base64 (clientId:clientSecret) → send as-is after "Basic "
# STANBIC_API_KEY_AUTHORIZATION_RAW=false  # ONLY if Stanbic gave a plain id and NI docs say encode Base64(`${id}:`) — wrong for composite Base64 keys
#
# Longer names still supported:
# STANBIC_API_GATEWAY_URL=   (same as STANBIC_GATEWAY_URL)
# STANBIC_REALM_NAME=        (same as STANBIC_REALM)
# STANBIC_MERCHANT_API_KEY= (same as STANBIC_API_KEY)
# STANBIC_OUTLET_REFERENCE= (same as STANBIC_OUTLET_REF)
#
# STANBIC_VERBOSE_ERRORS=true  # append Stanbic upstream body to auth error toast (temporary debug)
# STANBIC_ENV=sandbox                 # optional label only — does not override gateway/realm/key
#
# STANBIC_IDENTITY_URL=   # only if Stanbic pack uses a separate identity host; usually leave unset
# STANBIC_PAYPAGE_URL=https://paypage.sandbox.stanbicbank.co.zw
# Sandbox docs: https://docs.ngenius-payments.com/reference/sandbox-test-environment
# ---------------------------------------------------------------------------
# STANBIC_ORDER_ACTION=PURCHASE
# STANBIC_FETCH_TIMEOUT_MS=45000
# STANBIC_PAY_LOG_LABEL=stanbic-pay
# Optional: override hosted payment amount for all packages (minor units, e.g. 5000 = USD 50.00). Leave unset to use package tier pricing from src/lib/registrationPackages.ts
# REGISTRATION_FEE_MINOR_UNITS=
# REGISTRATION_FEE_CURRENCY=USD

# Public registration — set true to show the live form. Submissions are rejected after the published pricing period ends (see registrationPackages / getRegistrationPricingTier).
NEXT_PUBLIC_REGISTRATION_OPEN=true

APP_NAME=SARSYC VI Conference Platform
APP_URL=http://localhost:3000

# Security
JWT_SECRET=your-jwt-secret-key-here
BCRYPT_ROUNDS=10
