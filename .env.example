# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sarsyc_db

# Next.js Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Aliases for SMTP_PASS (same value): SMTP_PASSWORD, EMAIL_PASSWORD, MAIL_PASSWORD
SMTP_FROM=noreply@sarsyc.org

# ---------------------------------------------------------------------------
# Stanbic / N-Genius payments (Hosted Payment Page — redirect model)
# After portal onboarding: Integrations > Service Account (API key); Outlet ref under hierarchy.
# Sandbox docs: https://docs.ngenius-payments.com/reference/sandbox-test-environment
# ---------------------------------------------------------------------------
# STANBIC_REALM_NAME=StanbicBankZimbabweSandbox
# STANBIC_API_GATEWAY_URL=https://api-gateway.sandbox.stanbicbank.co.zw
# STANBIC_PAYPAGE_URL=https://paypage.sandbox.stanbicbank.co.zw
# STANBIC_IDENTITY_URL=https://identity.sandbox.stanbicbank.co.zw
# STANBIC_PORTAL_URL=https://portal.sandbox.stanbicbank.co.zw
# STANBIC_MERCHANT_API_KEY=
# STANBIC_OUTLET_REFERENCE=
# If the portal gives a pre-formed Basic string, use: STANBIC_API_KEY_AUTHORIZATION_RAW=true (raw value after "Basic ").
# STANBIC_ORDER_ACTION=PURCHASE
# Per-request timeout to N-Genius (ms); min 5000, max 120000. Helps avoid Vercel timeouts on slow gateway.
# STANBIC_FETCH_TIMEOUT_MS=45000
# Log tag for JSON payment lines, e.g. stanbic-cert → [stanbic-cert] {"event":"stanbic_start",...}
# STANBIC_PAY_LOG_LABEL=stanbic-pay
# Optional: override hosted payment amount for all packages (minor units, e.g. 5000 = USD 50.00). Leave unset to use package tier pricing from src/lib/registrationPackages.ts
# REGISTRATION_FEE_MINOR_UNITS=
# REGISTRATION_FEE_CURRENCY=USD

# Public registration — set true to show the live form. Submissions are rejected after the published pricing period ends (see registrationPackages / getRegistrationPricingTier).
NEXT_PUBLIC_REGISTRATION_OPEN=true

APP_NAME=SARSYC VI Conference Platform
APP_URL=http://localhost:3000

# Security
JWT_SECRET=your-jwt-secret-key-here
BCRYPT_ROUNDS=10
